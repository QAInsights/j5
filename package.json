    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.3.2",
    "vitest": "^4.1.8"
  }
}
