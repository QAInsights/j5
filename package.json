{
  "name": "j5-js",
  "version": "0.1.0",
  "description": "k6-style TypeScript DSL for Apache JMeter",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "j5": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
